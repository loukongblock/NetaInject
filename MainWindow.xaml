<Window x:Class="Neta.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Neta" Height="600" Width="960"
        MinHeight="600" MinWidth="920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Grid Background="Transparent" x:Name="grid">
        <Border x:Name="MaskBorder" CornerRadius="12" Background="#01000000"/>
        <Border x:Name="MainBorder" CornerRadius="12" Background="Transparent">
            <Grid>
                <!-- 边缘缩放 -->
                <Grid Panel.ZIndex="10">
                    <Rectangle x:Name="LeftResizeRect" Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                    <Rectangle x:Name="RightResizeRect" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                    <Rectangle x:Name="TopResizeRect" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Top" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                    <Rectangle x:Name="BottomResizeRect" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                    <Rectangle x:Name="TopLeftResizeRect" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                    <Rectangle x:Name="TopRightResizeRect" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                    <Rectangle x:Name="BottomLeftResizeRect" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                    <Rectangle x:Name="BottomRightResizeRect" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="ResizeBorder_MouseLeftButtonDown"/>
                </Grid>

                <!-- 标题栏 -->
                <Border Height="40" VerticalAlignment="Top" Background="Transparent" x:Name="TitleBar">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Neta" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#EEEEEE" FontSize="13" FontWeight="Medium"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,1,15,0" HorizontalAlignment="Right">
                            <TextBlock FontFamily="{StaticResource Icon}"
                                       FontSize="16" Foreground="White"
                                       MouseLeftButtonDown="hidewindow_MouseLeftButtonDown"
                                       Text="&#xe65a;"
                                       ToolTip="最小化"/>
                            <TextBlock FontFamily="{StaticResource Icon}" Visibility="Collapsed"
                                       FontSize="16" Foreground="White"
                                       MouseLeftButtonDown="MaxRestoreButton_MouseLeftButtonDown"
                                       x:Name="MaxRestoreButton"
                                       Margin="20,0,20,0"
                                       Text="&#xe65b;"
                                       ToolTip="最大化/还原"/>
                            <TextBlock FontFamily="{StaticResource Icon}"
                                       Margin="20,1.65,0,0"
                                       FontSize="12" Foreground="White"
                                       MouseLeftButtonDown="close_MouseLeftButtonDown"
                                       Text="&#xe502;"
                                       ToolTip="关闭"/>
                        </StackPanel>

                        <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="1" Background="#22FFFFFF"/>
                    </Grid>
                </Border>

                <!-- 主内容：进程列表 + 进度条 -->
                <Grid Margin="0,40,0,0" Background="Transparent">
                    <TextBlock FontSize="12" Foreground="#55FFFFFF" Text="Copyright (c) 2026 Loukongblock. All rights reserved." HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10"/>
                    <!-- 版本号，由代码动态设置 -->
                    <TextBlock x:Name="VersionText" FontSize="12" Foreground="#55FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10"/>
                    <!-- 添加 Margin="0,-20,0,0" 补偿标题栏的偏移 -->
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-20,0,0">
                        <!-- 进程列表 -->
                        <StackPanel x:Name="ProcessListPanel" Margin="0,0,0,40">
                            <TextBlock FontSize="24" Foreground="White" Text="选择 Minecraft 进程" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>

                        <!-- 进度条面板（内容本身已水平居中） -->
                        <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Width="280" Margin="0,0,0,40">
                            <TextBlock FontSize="24" Foreground="White" Text="正在注入..." HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock x:Name="ProgressText" Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10" Text="0%"/>
                            <Border CornerRadius="3" Background="#33FFFFFF" Height="5">
                                <ProgressBar x:Name="InjectProgressBar" 
                                             Minimum="0" Maximum="100" Value="0"
                                             Background="Transparent"
                                             Foreground="#FFFFFFFF"
                                             BorderThickness="0">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border CornerRadius="3" Background="Transparent">
                                                <Grid>
                                                    <Border x:Name="PART_Track" Background="Transparent"/>
                                                    <Border x:Name="PART_Indicator" 
                                                            CornerRadius="3"
                                                            HorizontalAlignment="Left"
                                                            Background="{TemplateBinding Foreground}"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <!-- 使用须知覆盖层 -->
                    <Grid x:Name="DisclaimerOverlay" Panel.ZIndex="100" Visibility="Visible" Margin="0,0,0,40">
                        <Border Background="Transparent" CornerRadius="12" BorderBrush="Transparent" BorderThickness="0"
                                Width="400" Height="240" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="使用须知" FontSize="20" Foreground="White"
                                           HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                <TextBlock Text="1.本软件仅供学习参考，请在24小时内删除&#x0a;2.不可注入网易版我的世界，仅可注入国际版我的世界&#x0a;3.不可用于多人服务器/多人游戏，仅可在单人世界使用&#x0a;4.违反以上条约，后果自负"
                                           FontSize="14" Foreground="White"
                                           Width="500" HorizontalAlignment="Center" Margin="0,0,0,25"
                                           TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="不接受" Width="110" Height="36" Margin="0,0,20,0"
                                            Background="#22FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1"
                                            Foreground="White" FontSize="14"
                                            Click="Decline_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="接受" Width="110" Height="36"
                                            Background="#22FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1"
                                            Foreground="White" FontSize="14"
                                            Click="Accept_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 【新增】关注提示覆盖层 -->
                    <Grid x:Name="FollowOverlay" Panel.ZIndex="100" Visibility="Collapsed" Margin="0,0,0,40">
                        <Border Background="Transparent" CornerRadius="12" BorderBrush="Transparent" BorderThickness="0"
                                Width="400" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="在使用之前，能不能关注一下loukongblock呢？" FontSize="18" Foreground="White"
                                           HorizontalAlignment="Center" Margin="0,0,0,20" TextWrapping="Wrap" TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="当然可以" Width="120" Height="36" Margin="0,0,20,0"
                                            Background="#22FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1"
                                            Foreground="White" FontSize="14"
                                            Click="FollowYes_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="下次一定" Width="120" Height="36"
                                            Background="#22FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1"
                                            Foreground="White" FontSize="14"
                                            Click="FollowLater_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>